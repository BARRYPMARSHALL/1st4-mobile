# 1st 4 Mobile — Environment Variables
# Copy this to .env and fill in your values.

# Database (Railway Postgres plugin sets DATABASE_URL automatically)
# Local dev: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/first4mobile

# Frontend API URL (Railway sets this to the backend service URL)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Flask-style secret (generated: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-string

# Logging
LOG_LEVEL=INFO
